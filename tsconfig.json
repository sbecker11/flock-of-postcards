{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["vite/client"]
  },
  "include": ["modules/**/*.ts", "modules/**/*.d.ts", "modules/**/*.vue", "main.ts", "vite.config.js", "modules/**/*.mjs", "static_content/**/*.mjs", "env.d.ts", "shims-vue.d.ts"],
} 